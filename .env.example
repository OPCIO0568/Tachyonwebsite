# Tachyon website environment example
#
# This file is only a sample.
# The server does not automatically load .env files.
# Use these values in your shell, systemd service, or hosting environment.

# Server port
PORT=4321

# Initial admin password.
# This is used only when data/auth.json does not exist.
# Change this before running the production server.
TACHYON_ADMIN_PASSWORD=change-this-password

# Production runtime marker
NODE_ENV=production
