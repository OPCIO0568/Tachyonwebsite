---
import BaseLayout from "../layouts/BaseLayout.astro";
import fallbackHistoryData from "../../data/history.json";
import { renderHistoryAwards, renderHistoryMain } from "../utils/publicContent.js";
---

<BaseLayout title={fallbackHistoryData.title} description={fallbackHistoryData.description}>
  <section class="section">
    <div class="container" id="history-app">
      <Fragment set:html={renderHistoryMain(fallbackHistoryData)} />
    </div>
  </section>

  <section class="section" id="awards">
    <div class="container" id="awards-app">
      <Fragment set:html={renderHistoryAwards(fallbackHistoryData)} />
    </div>
  </section>

  <script>
    import { normalizeHistory, renderHistoryAwards, renderHistoryMain } from "../utils/publicContent.js";

    const app = document.getElementById("history-app");
    const awardsSection = document.getElementById("awards-app");

    const render = (data) => {
      const history = normalizeHistory(data);
      document.title = history.title;
      document.querySelector('meta[name="description"]')?.setAttribute("content", history.description);
      app.innerHTML = renderHistoryMain(data);
      if (awardsSection) {
        awardsSection.innerHTML = renderHistoryAwards(data);
      }
    };

    const loadHistory = async () => {
      try {
        const response = await fetch("/api/history", { cache: "no-store" });
        if (!response.ok) {
          throw new Error("Failed to load history");
        }
        return await response.json();
      } catch {
        return null;
      }
    };

    const start = () =>
      loadHistory().then((data) => {
        if (data) {
          render(data);
        }
      });
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", start, { once: true });
    } else {
      start();
    }
  </script>
</BaseLayout>
