---
import BaseLayout from "../layouts/BaseLayout.astro";
import fallbackSponsorsData from "../../data/sponsors.json";
import { renderSponsors } from "../utils/publicContent.js";
---

<BaseLayout title={fallbackSponsorsData.title} description={fallbackSponsorsData.description}>
  <section class="section">
    <div class="container" id="sponsors-app">
      <Fragment set:html={renderSponsors(fallbackSponsorsData)} />
    </div>
  </section>

  <script>
    import { normalizeSponsors, renderSponsors } from "../utils/publicContent.js";

    const app = document.getElementById("sponsors-app");

    const render = (data) => {
      const sponsors = normalizeSponsors(data);
      document.title = sponsors.title;
      document.querySelector('meta[name="description"]')?.setAttribute("content", sponsors.description);
      app.innerHTML = renderSponsors(data);
    };

    const loadSponsors = async () => {
      try {
        const response = await fetch("/api/sponsors", { cache: "no-store" });
        if (!response.ok) {
          throw new Error("Failed to load sponsors");
        }
        return await response.json();
      } catch {
        return null;
      }
    };

    loadSponsors().then((data) => {
      if (data) {
        render(data);
      }
    });
  </script>
</BaseLayout>
