---
import BaseLayout from "../layouts/BaseLayout.astro";
import fallbackGalleryData from "../../data/gallery.json";
import { renderGallery } from "../utils/publicContent.js";
---

<BaseLayout title={fallbackGalleryData.title} description={fallbackGalleryData.description}>
  <section class="section">
    <div class="container">
      <div id="gallery-app" class="gallery-app">
        <Fragment set:html={renderGallery(fallbackGalleryData)} />
      </div>
    </div>
  </section>

  <script>
    import { normalizeGallery, renderGallery } from "../utils/publicContent.js";

    const app = document.getElementById("gallery-app");

    const render = (data) => {
      const gallery = normalizeGallery(data);
      document.title = gallery.title === "Tachyon" ? gallery.title : `${gallery.title} | Tachyon`;
      document.querySelector('meta[name="description"]')?.setAttribute("content", gallery.description);
      app.innerHTML = renderGallery(data);
    };

    const loadGallery = async () => {
      try {
        const response = await fetch("/api/gallery", { cache: "no-store" });
        if (!response.ok) {
          throw new Error("Failed to load gallery");
        }
        return await response.json();
      } catch {
        return null;
      }
    };

    loadGallery().then((data) => {
      if (data) {
        render(data);
      }
    });
  </script>
</BaseLayout>
