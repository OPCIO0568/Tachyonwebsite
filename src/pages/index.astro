---
import BaseLayout from "../layouts/BaseLayout.astro";
import fallbackHomeData from "../../data/home.json";
import { renderHome } from "../utils/publicContent.js";
---

<BaseLayout title={fallbackHomeData.title} description={fallbackHomeData.description}>
  <div id="home-app">
    <Fragment set:html={renderHome(fallbackHomeData)} />
  </div>

  <script>
    import { normalizeHome, renderHome } from "../utils/publicContent.js";

    const app = document.getElementById("home-app");

    const render = (data) => {
      const home = normalizeHome(data);
      document.title = home.title;
      document.querySelector('meta[name="description"]')?.setAttribute("content", home.description);
      app.innerHTML = renderHome(data);
    };

    const loadHome = async () => {
      try {
        const response = await fetch("/api/home", { cache: "no-store" });
        if (!response.ok) {
          throw new Error("Failed to load home");
        }
        return await response.json();
      } catch {
        return null;
      }
    };

    loadHome().then((data) => {
      if (data) {
        render(data);
      }
    });
  </script>
</BaseLayout>
