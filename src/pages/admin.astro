    const handleGalleryAction = async (actionEl) => {
      const action = actionEl.dataset.action;
      readGalleryFromDom();
      const itemIndex = Number(actionEl.dataset.itemIndex);

      if (action === "add-gallery-grid-row-top") {
        const nextGridRows = normalizeGalleryGridRows(galleryData.gridRows + 1);
        galleryData.items = galleryData.items.map((item, index) => moveGalleryItemRows(item, 1, nextGridRows, index));
        galleryData.gridRows = nextGridRows;
      }
      if (action === "add-gallery-grid-row-bottom") {
        galleryData.gridRows = normalizeGalleryGridRows(galleryData.gridRows + 1);
      }
      if (action === "remove-gallery-grid-row-top") {
        const nextGridRows = normalizeGalleryGridRows(galleryData.gridRows - 1);
        galleryData.items = galleryData.items.map((item, index) => moveGalleryItemRows(item, -1, nextGridRows, index));
        galleryData.gridRows = nextGridRows;
      }
      if (action === "remove-gallery-grid-row-bottom") {
        galleryData.gridRows = normalizeGalleryGridRows(galleryData.gridRows - 1);
        galleryData.items = galleryData.items.map((item, index) => normalizeGalleryItem(item, galleryData.gridRows, index));
      }
      if (action === "select-gallery-item") {
        selectedGalleryItemIndex = itemIndex;
      }
      if (action === "set-gallery-filter") {
        selectedGalleryFilter = actionEl.dataset.filter || "all";
        selectedGalleryPage = 1;
      }
      if (action === "set-gallery-page") {
        selectedGalleryPage = Math.max(1, Math.min(Number(actionEl.dataset.page) || 1, galleryPageCount()));
      }
      if (action === "set-gallery-size") {
        const item = galleryData.items[itemIndex];
        if (item) {
          item.size = normalizeGallerySize(actionEl.dataset.size);
          if (item.size !== 6 && (item.mediaType === "video" || item.mediaType === "youtube")) {
            item.image = "";
            item.mediaType = "image";
          }
          selectedGalleryItemIndex = itemIndex;
        }
      }
      if (action === "add-gallery-item") {
        const itemId = nextGalleryItemId();
        galleryData.items.push({
          id: itemId,
          title: `Photo ${itemId}`,
          image: "",
          alt: "",
          mediaType: "image",
          size: 1,
          placed: false,
          cells: [],
        });
        selectedGalleryItemIndex = galleryData.items.length - 1;
        selectedGalleryFilter = "all";
        ensureSelectedGalleryVisible();
      }
      if (action === "place-gallery-item") {
        const cellIndex = Number(actionEl.dataset.cellIndex);
        const item = selectedGalleryItem();
        if (item) {
          const placementCells = galleryPlacementCells(cellIndex, item.size, galleryData.gridRows);
          const blockedCells = new Set(
            galleryData.items.flatMap((galleryItem, index) =>
              index === selectedGalleryItemIndex || galleryItem.placed === false ? [] : normalizeGalleryCells(galleryItem.cells, galleryData.gridRows),
            ),
          );

          if (placementCells.some((cell) => blockedCells.has(cell))) {
            setStatus("이미 다른 사진이 배치된 영역입니다.", "error");
            return;
          }

          item.cells = placementCells;
          item.placed = true;
        }
      }
      if (action === "clear-gallery-placement") {
        const item = galleryData.items[itemIndex];
        if (item) {
          item.cells = [];
          item.placed = false;
          selectedGalleryItemIndex = itemIndex;
        }
      }
      if (action === "remove-gallery-item") {
        galleryData.items.splice(itemIndex, 1);
        selectedGalleryItemIndex = Math.max(0, Math.min(selectedGalleryItemIndex, galleryData.items.length - 1));
        ensureSelectedGalleryVisible();
      }
      if (action === "move-gallery-item-up") {
        swap(galleryData.items, itemIndex, itemIndex - 1);
        selectedGalleryItemIndex = Math.max(0, itemIndex - 1);
        ensureSelectedGalleryVisible();
      }
      if (action === "move-gallery-item-down") {
        swap(galleryData.items, itemIndex, itemIndex + 1);
        selectedGalleryItemIndex = Math.min(galleryData.items.length - 1, itemIndex + 1);
        ensureSelectedGalleryVisible();
      }

      renderGalleryEditor();
      setStatus("");
    };

    const handleAction = async (actionEl) => {
      const action = actionEl.dataset.action;
      readCurrentEditorFromDom();

      if (action === "add-season") {
        const year = nextSeasonYear();
        membersData.seasons.unshift({
          year,
          title: `Members ${year}`,
          subtitle: `Tachyon Season ${year}.`,
          teamPhotos: [],
          sections: [],
        });
        selectedYear = `season:${year}`;
        renderEditor();
        setStatus("");
        return;
      }

      if (action === "save") {
        await saveData();
        return;
      }

      if (action === "back-pages") {
        adminEditor.hidden = true;
        adminPages.hidden = false;
        setStatus("");
        return;
      }

      if (action === "logout") {
        await requestJson("/api/admin/logout", { method: "POST" });
        adminEditor.hidden = true;
        adminPages.hidden = true;
        loginPanel.hidden = false;
        setStatus("");
        return;
      }

      if (selectedKind() === "archive") {
        const groupIndex = Number(actionEl.dataset.groupIndex);
        const photoIndex = Number(actionEl.dataset.photoIndex);

        if (action === "add-archive-group") {
          membersData.archive.groups.push({ label: "New Archive", photos: [] });
        }
        if (action === "remove-archive-group") {
          membersData.archive.groups.splice(groupIndex, 1);
        }
        if (action === "move-archive-group-up") {
          swap(membersData.archive.groups, groupIndex, groupIndex - 1);
        }
        if (action === "move-archive-group-down") {
          swap(membersData.archive.groups, groupIndex, groupIndex + 1);
        }
        if (action === "add-archive-photo") {
          membersData.archive.groups[groupIndex].photos.push("");
        }
        if (action === "remove-archive-photo") {
          membersData.archive.groups[groupIndex].photos.splice(photoIndex, 1);
        }

        renderEditor();
        setStatus("");
        return;
      }

      if (selectedKind() === "ob") {
        const memberIndex = Number(actionEl.dataset.memberIndex);
        const photoIndex = Number(actionEl.dataset.photoIndex);

        if (action === "add-team-photo") {
          membersData.ob.teamPhotos.push("");
        }
        if (action === "remove-team-photo") {
          membersData.ob.teamPhotos.splice(photoIndex, 1);
        }
        if (action === "add-ob-member") {
          membersData.ob.members.push({
            name: "",
            role: "OB",
            email: "",
            photo: defaultPhoto,
          });
        }
        if (action === "remove-ob-member") {
          membersData.ob.members.splice(memberIndex, 1);
        }
        if (action === "move-ob-member-up") {
          swap(membersData.ob.members, memberIndex, memberIndex - 1);
        }
        if (action === "move-ob-member-down") {
          swap(membersData.ob.members, memberIndex, memberIndex + 1);
        }

        renderEditor();
        setStatus("");
        return;
      }

      const season = currentSeason();
      if (!season) {
        return;
      }

      const sectionIndex = Number(actionEl.dataset.sectionIndex);
      const groupIndex = Number(actionEl.dataset.groupIndex);
      const memberIndex = Number(actionEl.dataset.memberIndex);
      const photoIndex = Number(actionEl.dataset.photoIndex);

      if (action === "add-team-photo") {
        season.teamPhotos.push("");
      }
      if (action === "remove-team-photo") {
        season.teamPhotos.splice(photoIndex, 1);
      }
      if (action === "add-section") {
        season.sections.push({ title: "New Section", groups: [] });
      }
      if (action === "remove-section") {
        season.sections.splice(sectionIndex, 1);
      }
      if (action === "move-section-up") {
        swap(season.sections, sectionIndex, sectionIndex - 1);
      }
      if (action === "move-section-down") {
        swap(season.sections, sectionIndex, sectionIndex + 1);
      }
      if (action === "add-group") {
        season.sections[sectionIndex].groups.push({ title: "New Group", members: [] });
      }
      if (action === "remove-group") {
        season.sections[sectionIndex].groups.splice(groupIndex, 1);
      }
      if (action === "move-group-up") {
        swap(season.sections[sectionIndex].groups, groupIndex, groupIndex - 1);
      }
      if (action === "move-group-down") {
        swap(season.sections[sectionIndex].groups, groupIndex, groupIndex + 1);
      }
      if (action === "add-member") {
        season.sections[sectionIndex].groups[groupIndex].members.push({
          name: "",
          role: "",
          email: "",
          photo: defaultPhoto,
        });
      }
      if (action === "remove-member") {
        season.sections[sectionIndex].groups[groupIndex].members.splice(memberIndex, 1);
      }
      if (action === "move-member-up") {
        swap(season.sections[sectionIndex].groups[groupIndex].members, memberIndex, memberIndex - 1);
      }
      if (action === "move-member-down") {
        swap(season.sections[sectionIndex].groups[groupIndex].members, memberIndex, memberIndex + 1);
      }

      renderEditor();
      setStatus("");
    };

    loginForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      try {
        await requestJson("/api/admin/login", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ password: passwordInput.value }),
        });
        passwordInput.value = "";
        await showPageList();
      } catch (error) {
        setStatus(error.message, "error");
      }
    });

    seasonSelect.addEventListener("change", () => {
      readCurrentEditorFromDom();
      selectedYear = seasonSelect.value;
      renderEditor();
      setStatus("");
    });

    adminVisitPageSelect.addEventListener("change", () => {
      selectedVisitRoute = adminVisitPageSelect.value;
      renderVisitChart();
      setStatus("");
    });

    adminPages.addEventListener("click", async (event) => {
      const actionEl = event.target.closest("[data-action]");
      if (!actionEl) {
        return;
      }

      try {
        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "members") {
          await loadMembersEditor();
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "home") {
          await loadHomeEditor();
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "home-en") {
          await loadHomeEditor("home-en");
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "intro") {
          await loadIntroEditor();
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "intro-en") {
          await loadIntroEditor("intro-en");
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "history") {
          await loadHistoryEditor();
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "gallery") {
          await loadGalleryEditor();
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "sponsors") {
          await loadSponsorsEditor();
        }

        if (actionEl.dataset.action === "open-editor" && actionEl.dataset.editor === "contact") {
          await loadContactEditor();
        }

        if (actionEl.dataset.action === "logout") {
          await requestJson("/api/admin/logout", { method: "POST" });
          adminPages.hidden = true;
          loginPanel.hidden = false;
          setStatus("");
        }
      } catch (error) {
        setStatus(error.message, "error");
      }
    });

    adminPasswordForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (newPasswordInput.value !== confirmPasswordInput.value) {
        setStatus("새 비밀번호 확인이 일치하지 않습니다.", "error");
        return;
      }

      try {
        await requestJson("/api/admin/change-password", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            currentPassword: currentPasswordInput.value,
            newPassword: newPasswordInput.value,
          }),
        });

        adminPasswordForm.reset();
        setStatus("비밀번호를 변경했습니다.", "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    });

    adminEditor.addEventListener("click", (event) => {
      const actionEl = event.target.closest("[data-action]");
      if (!actionEl || actionEl.type === "file") {
        return;
      }

      const action = actionEl.dataset.action;

      if (action === "save") {
        const save =
          activeEditor === "sponsors"
            ? saveSponsorsData
            : isHomeEditor()
              ? saveHomeData
            : isIntroEditor()
              ? saveIntroData
            : activeEditor === "history"
              ? saveHistoryData
            : activeEditor === "gallery"
              ? saveGalleryData
            : activeEditor === "contact"
              ? saveContactData
              : saveData;
        save().catch((error) => setStatus(error.message, "error"));
        return;
      }

      if (action === "back-pages") {
        adminEditor.hidden = true;
        adminPages.hidden = false;
        setStatus("");
        return;
      }

      if (action === "logout") {
        requestJson("/api/admin/logout", { method: "POST" })
          .then(() => {
            adminEditor.hidden = true;
            adminPages.hidden = true;
            loginPanel.hidden = false;
            setStatus("");
          })
          .catch((error) => setStatus(error.message, "error"));
        return;
      }

      const handler =
        activeEditor === "sponsors"
          ? handleSponsorsAction
          : isHomeEditor()
            ? handleHomeAction
          : isIntroEditor()
            ? handleIntroAction
          : activeEditor === "history"
            ? handleHistoryAction
          : activeEditor === "gallery"
            ? handleGalleryAction
          : activeEditor === "contact"
            ? handleContactAction
            : handleAction;
      handler(actionEl).catch((error) => setStatus(error.message, "error"));
    });

    adminEditor.addEventListener("change", async (event) => {
      const fileInput = event.target.closest('input[type="file"][data-action]');
      if (!fileInput || !fileInput.files?.[0]) {
        return;
      }

      try {
        if (activeEditor === "sponsors") {
          readSponsorsFromDom();
          const action = fileInput.dataset.action;
          const path = await uploadFileTo(fileInput.files[0], "sponsors", action === "upload-sponsor-hero" ? "hero" : "logos");

          if (action === "upload-sponsor-hero") {
            sponsorsData.heroImage = path;
          }

          if (action === "upload-sponsor-logo") {
            sponsorsData.items[Number(fileInput.dataset.sponsorIndex)].logo = path;
          }

          renderSponsorsEditor();
          setStatus("이미지를 업로드했습니다. 저장을 눌러 반영하세요.", "success");
          return;
        }

        if (isHomeEditor()) {
          readHomeFromDom();
          const action = fileInput.dataset.action;
          const category = activeEditor === "home-en" ? "home-en" : "home";
          const bucket =
            action === "upload-home-hero-light" || action === "upload-home-hero-dark"
              ? "hero"
              : action === "upload-home-card"
                ? "cards"
                : "contact";
          const path = await uploadFileTo(fileInput.files[0], category, bucket);

          if (action === "upload-home-hero-light") {
            homeData.hero.lightImage = path;
          }
          if (action === "upload-home-hero-dark") {
            homeData.hero.darkImage = path;
          }
          if (action === "upload-home-card") {
            homeData.cards[Number(fileInput.dataset.cardIndex)].image = path;
          }
          if (action === "upload-home-photo") {
            homeData.contact.photos[Number(fileInput.dataset.photoIndex)].image = path;
          }

          renderHomeEditor();
          setStatus("이미지를 업로드했습니다. 저장을 눌러 반영하세요.", "success");
          return;
        }

        if (isIntroEditor()) {
          readIntroFromDom();
          const category = activeEditor === "intro-en" ? "intro-en" : "intro";
          const path = await uploadFileTo(fileInput.files[0], category, "organization");
          introData.organization.image = path;
          renderIntroEditor();
          setStatus("이미지를 업로드했습니다. 저장을 눌러 반영하세요.", "success");
          return;
        }

        if (activeEditor === "history") {
          readHistoryFromDom();
          const path = await uploadFileTo(fileInput.files[0], "history", "vehicles");
          const group = historyData.groups[Number(fileInput.dataset.groupIndex)];
          const vehicle = group?.vehicles[Number(fileInput.dataset.vehicleIndex)];
          if (vehicle) {
            vehicle.image = path;
          }

          renderHistoryEditor();
          setStatus("이미지를 업로드했습니다. 저장을 눌러 반영하세요.", "success");
          return;
        }

        if (activeEditor === "gallery") {
          readGalleryFromDom();
          const itemIndex = Number(fileInput.dataset.itemIndex);
          const item = galleryData.items[itemIndex];
          const isVideo = fileInput.files[0].type.startsWith("video/");
          if (isVideo && item?.size !== 6) {
            throw new Error("영상은 6칸 항목에서만 업로드할 수 있습니다.");
          }
          const path = await uploadFileTo(fileInput.files[0], "gallery", isVideo ? "videos" : "photos");
          if (item) {
            item.image = path;
            item.alt = item.title;
            item.mediaType = isVideo ? "video" : "image";
            selectedGalleryItemIndex = itemIndex;
          }

          renderGalleryEditor();
          setStatus(`${isVideo ? "영상을" : "이미지를"} 업로드했습니다. 저장을 눌러 반영하세요.`, "success");
          return;
        }

        if (activeEditor === "contact") {
          readContactFromDom();
          const action = fileInput.dataset.action;
          const path = await uploadFileTo(fileInput.files[0], "contact", action === "upload-contact-hero" ? "hero" : "socials");

          if (action === "upload-contact-hero") {
            contactData.heroImage = path;
          }

          if (action === "upload-contact-social") {
            contactData.socials[Number(fileInput.dataset.socialIndex)].image = path;
          }

          renderContactEditor();
          setStatus("이미지를 업로드했습니다. 저장을 눌러 반영하세요.", "success");
          return;
        }

        readCurrentEditorFromDom();
        const kind = selectedKind();
        const season = currentSeason();
        const action = fileInput.dataset.action;
        const purpose =
          action === "upload-team-photo"
            ? "team-photo"
            : action === "upload-archive-photo"
              ? "archive-photo"
              : "";
        const path = await uploadFile(fileInput.files[0], selectedUploadBucket(), purpose);

        if (fileInput.dataset.action === "upload-team-photo") {
          if (kind === "ob") {
            membersData.ob.teamPhotos[Number(fileInput.dataset.photoIndex)] = path;
          } else if (season) {
            season.teamPhotos[Number(fileInput.dataset.photoIndex)] = path;
          }
        }

        if (fileInput.dataset.action === "upload-member-photo") {
          const section = season.sections[Number(fileInput.dataset.sectionIndex)];
          const group = section.groups[Number(fileInput.dataset.groupIndex)];
          const member = group.members[Number(fileInput.dataset.memberIndex)];
          member.photo = path;
        }

        if (fileInput.dataset.action === "upload-ob-member-photo") {
          const member = membersData.ob.members[Number(fileInput.dataset.memberIndex)];
          member.photo = path;
        }

        if (fileInput.dataset.action === "upload-archive-photo") {
          const group = membersData.archive.groups[Number(fileInput.dataset.groupIndex)];
          group.photos[Number(fileInput.dataset.photoIndex)] = path;
        }

        renderEditor();
        setStatus("이미지를 업로드했습니다. 저장을 눌러 반영하세요.", "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    });

    const showPageList = async () => {
      sitePages = (await requestJson("/api/admin/pages")).map(normalizePage);
      visitsData = normalizeVisitsData(await requestJson("/api/admin/visits"));
      renderPageList();
      loginPanel.hidden = true;
      adminPages.hidden = false;
      adminEditor.hidden = true;
      setStatus("");
    };

    const loadMembersEditor = async () => {
      setEditorChrome("members");
      membersData = normalizeData(await requestJson("/api/members"));
      sortSeasons();
      selectedYear = membersData.seasons[0] ? `season:${membersData.seasons[0].year}` : "archive";
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderEditor();
      setStatus("");
    };

    const loadHomeEditor = async (editor = "home") => {
      setEditorChrome(editor);
      homeData = normalizeHomeData(await requestJson(homeApiPath()));
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderHomeEditor();
      setStatus("");
    };

    const loadIntroEditor = async (editor = "intro") => {
      setEditorChrome(editor);
      introData = normalizeIntroData(await requestJson(introApiPath()));
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderIntroEditor();
      setStatus("");
    };

    const loadHistoryEditor = async () => {
      setEditorChrome("history");
      historyData = normalizeHistoryData(await requestJson("/api/history"));
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderHistoryEditor();
      setStatus("");
    };

    const loadGalleryEditor = async () => {
      setEditorChrome("gallery");
      galleryData = normalizeGalleryData(await requestJson("/api/gallery"));
      selectedGalleryItemIndex = 0;
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderGalleryEditor();
      setStatus("");
    };

    const loadSponsorsEditor = async () => {
      setEditorChrome("sponsors");
      sponsorsData = normalizeSponsorsData(await requestJson("/api/sponsors"));
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderSponsorsEditor();
      setStatus("");
    };

    const loadContactEditor = async () => {
      setEditorChrome("contact");
      contactData = normalizeContactData(await requestJson("/api/contact"));
      loginPanel.hidden = true;
      adminPages.hidden = true;
      adminEditor.hidden = false;
      renderContactEditor();
      setStatus("");
    };

    const init = async () => {
      try {
        const session = await requestJson("/api/admin/session");
        if (session.authenticated) {
          await showPageList();
        }
      } catch {
        loginPanel.hidden = false;
      }
    };

    init();
  </script>
</BaseLayout>
