---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Tachyon Admin" description="Tachyon 관리자 페이지">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Admin</h1>

      <div id="admin-login" class="admin-panel">
        <form id="login-form" class="admin-form">
          <label class="admin-field">
            <span>비밀번호</span>
            <input id="admin-password" type="password" autocomplete="current-password" required />
          </label>
          <button class="admin-button admin-button-primary" type="submit">로그인</button>
        </form>
      </div>

      <p id="admin-status" class="admin-status" aria-live="polite"></p>

      <div id="admin-pages" class="admin-shell" hidden>
        <div class="admin-toolbar">
          <h2 class="admin-heading">Pages</h2>
          <button class="admin-button" type="button" data-action="logout">로그아웃</button>
        </div>

        <div id="admin-page-grid" class="admin-page-grid"></div>

        <form id="admin-password-form" class="admin-subpanel admin-password-form">
          <div class="admin-subpanel-header">
            <h3>비밀번호 변경</h3>
          </div>
          <div class="admin-form-grid">
            <label class="admin-field">
              <span>현재 비밀번호</span>
              <input id="current-password" type="password" autocomplete="current-password" required />
            </label>
            <label class="admin-field">
              <span>새 비밀번호</span>
              <input id="new-password" type="password" autocomplete="new-password" minlength="8" required />
            </label>
            <label class="admin-field">
              <span>새 비밀번호 확인</span>
              <input id="confirm-password" type="password" autocomplete="new-password" minlength="8" required />
            </label>
          </div>
          <div>
            <button class="admin-button admin-button-primary" type="submit">비밀번호 변경</button>
          </div>
        </form>

        <div class="admin-subpanel admin-visit-panel">
          <div class="admin-subpanel-header">
            <h3>조회수 통계</h3>
            <label class="admin-field admin-field-inline">
              <span>페이지</span>
              <select id="admin-visit-page-select"></select>
            </label>
          </div>
          <div id="admin-visit-summary" class="admin-visit-summary"></div>
          <div id="admin-visit-chart" class="admin-visit-chart"></div>
        </div>
      </div>

      <div id="admin-editor" class="admin-shell" hidden>
        <div class="admin-toolbar">
          <button class="admin-button" type="button" data-action="back-pages">페이지 목록</button>
          <h2 id="admin-editor-title" class="admin-heading">Members</h2>
          <label id="members-item-field" class="admin-field admin-field-inline">
            <span>항목</span>
            <select id="season-select"></select>
          </label>
          <button id="add-season-button" class="admin-button" type="button" data-action="add-season">시즌 추가</button>
          <button class="admin-button admin-button-primary" type="button" data-action="save">저장</button>
          <button class="admin-button" type="button" data-action="logout">로그아웃</button>
        </div>

        <div id="season-editor"></div>
      </div>
    </div>
  </section>

  <script is:inline>
    const loginPanel = document.getElementById("admin-login");
    const loginForm = document.getElementById("login-form");
    const passwordInput = document.getElementById("admin-password");
    const adminPages = document.getElementById("admin-pages");
    const adminVisitSummary = document.getElementById("admin-visit-summary");
    const adminVisitPageSelect = document.getElementById("admin-visit-page-select");
    const adminVisitChart = document.getElementById("admin-visit-chart");
    const adminPageGrid = document.getElementById("admin-page-grid");
    const adminPasswordForm = document.getElementById("admin-password-form");
    const currentPasswordInput = document.getElementById("current-password");
    const newPasswordInput = document.getElementById("new-password");
    const confirmPasswordInput = document.getElementById("confirm-password");
    const adminEditor = document.getElementById("admin-editor");
    const adminEditorTitle = document.getElementById("admin-editor-title");
    const membersItemField = document.getElementById("members-item-field");
    const addSeasonButton = document.getElementById("add-season-button");
    const seasonSelect = document.getElementById("season-select");
    const seasonEditor = document.getElementById("season-editor");
    const statusEl = document.getElementById("admin-status");

    let membersData = null;
    let homeData = null;
    let introData = null;
    let historyData = null;
    let sponsorsData = null;
    let contactData = null;
    let galleryData = null;
    let visitsData = { total: 0, pages: {}, days: {}, updatedAt: "" };
    let sitePages = [];
    let activeEditor = "";
    let selectedYear = "";
    let selectedVisitRoute = "all";
    let selectedGalleryItemIndex = 0;
    let selectedGalleryPage = 1;
    let selectedGalleryFilter = "all";

    const defaultPhoto = "/images/profile/unprofile.jpg";

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const setStatus = (message, type = "") => {
      statusEl.textContent = message;
      statusEl.dataset.type = type;
    };

    const requestJson = async (url, options = {}) => {
      const response = await fetch(url, {
        credentials: "same-origin",
        ...options,
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.error || "요청을 처리하지 못했습니다.");
      }
      return data;
    };

    const normalizeMember = (member = {}) => ({
      name: member.name || "",
      role: member.role || "",
      email: member.email || "",
      photo: member.photo || defaultPhoto,
    });

    const normalizeGroup = (group = {}) => ({
      title: group.title || "",
      members: Array.isArray(group.members) ? group.members.map(normalizeMember) : [],
    });

    const normalizeSection = (section = {}) => ({
      title: section.title || "",
      groups: Array.isArray(section.groups) ? section.groups.map(normalizeGroup) : [],
    });

    const normalizeSeason = (season = {}) => ({
      year: String(season.year || ""),
      title: season.title || "",
      subtitle: season.subtitle || "",
      teamPhotos: Array.isArray(season.teamPhotos) ? season.teamPhotos : [],
      sections: Array.isArray(season.sections) ? season.sections.map(normalizeSection) : [],
    });

    const normalizeArchive = (archive = {}) => ({
      title: archive.title || "Members Archive",
      subtitle: archive.subtitle || "",
      groups: Array.isArray(archive.groups)
        ? archive.groups.map((group) => ({
            label: group.label || "",
            photos: Array.isArray(group.photos) ? group.photos : [],
          }))
        : [],
    });

    const normalizeOb = (ob = {}) => ({
      title: ob.title || "OB Members",
      subtitle: ob.subtitle || "",
      teamPhotos: Array.isArray(ob.teamPhotos) ? ob.teamPhotos : [],
      members: Array.isArray(ob.members) ? ob.members.map(normalizeMember) : [],
    });

    const normalizeData = (data = {}) => ({
      seasons: Array.isArray(data.seasons) ? data.seasons.map(normalizeSeason) : [],
      archive: normalizeArchive(data.archive),
      ob: normalizeOb(data.ob),
    });

    const normalizePage = (page = {}) => ({
      name: page.name || "",
      route: page.route || "",
      file: page.file || "",
      editor: page.editor || "",
    });

    const normalizeHomeCard = (card = {}) => ({
      label: card.label || "",
      href: card.href || "",
      image: card.image || "",
      alt: card.alt || "",
    });

    const normalizeHomePhoto = (photo = {}) => ({
      href: photo.href || "",
      image: photo.image || "",
      alt: photo.alt || "",
    });

    const normalizeHomeLink = (link = {}) => ({
      label: link.label || "",
      href: link.href || "",
    });

    const normalizeHomeData = (data = {}) => ({
      title: data.title || "Tachyon",
      description: data.description || "",
      hero: {
        lightImage: data.hero?.lightImage || "",
        darkImage: data.hero?.darkImage || "",
        alt: data.hero?.alt || "",
        title: data.hero?.title || "",
        lead: data.hero?.lead || "",
      },
      cards: Array.isArray(data.cards) ? data.cards.map(normalizeHomeCard) : [],
      contact: {
        title: data.contact?.title || "With US",
        photos: Array.isArray(data.contact?.photos) ? data.contact.photos.map(normalizeHomePhoto) : [],
        links: Array.isArray(data.contact?.links) ? data.contact.links.map(normalizeHomeLink) : [],
      },
    });

    const normalizeIntroSection = (section = {}) => ({
      heading: section.heading || "",
      paragraphs: Array.isArray(section.paragraphs) ? section.paragraphs : [],
    });

    const normalizeIntroData = (data = {}) => ({
      title: data.title || "동아리 소개",
      description: data.description || "",
      sections: Array.isArray(data.sections) ? data.sections.map(normalizeIntroSection) : [],
      organization: {
        title: data.organization?.title || "Organization",
        image: data.organization?.image || "",
        alt: data.organization?.alt || "",
      },
    });

    const normalizeHistoryVehicle = (vehicle = {}) => ({
      name: vehicle.name || "",
      year: vehicle.year || "",
      competition: vehicle.competition || "",
      award: vehicle.award || "",
      image: vehicle.image || "",
      alt: vehicle.alt || "",
    });

    const normalizeHistoryGroup = (group = {}) => ({
      title: group.title || "",
      vehicles: Array.isArray(group.vehicles) ? group.vehicles.map(normalizeHistoryVehicle) : [],
    });

    const normalizeHistoryAward = (award = {}) => ({
      year: award.year || "",
      competition: award.competition || "",
      vehicle: award.vehicle || "",
      result: award.result || "",
    });

    const normalizeHistoryData = (data = {}) => ({
      title: data.title || "Our Cars",
      description: data.description || "",
      vehicleSectionTitle: data.vehicleSectionTitle || "History",
      groups: Array.isArray(data.groups) ? data.groups.map(normalizeHistoryGroup) : [],
      awards: {
        title: data.awards?.title || "역대 수상 내역",
        items: Array.isArray(data.awards?.items) ? data.awards.items.map(normalizeHistoryAward) : [],
      },
    });

    const normalizeSponsor = (sponsor = {}) => ({
      name: sponsor.name || "",
      url: sponsor.url || "",
      logo: sponsor.logo || "",
    });

    const normalizeSponsorsData = (data = {}) => ({
      title: data.title || "Sponsors",
      description: data.description || "",
      heroImage: data.heroImage || "",
      items: Array.isArray(data.items) ? data.items.map(normalizeSponsor) : [],
    });

    const normalizeContactPerson = (person = {}) => ({
      role: person.role || "",
      name: person.name || "",
      phone: person.phone || "",
      email: person.email || "",
    });

    const normalizeContactSocial = (social = {}) => ({
      name: social.name || "",
      url: social.url || "",
      image: social.image || "",
    });

    const normalizeContactData = (data = {}) => ({
      title: data.title || "Contact Us",
      subtitle: data.subtitle || "",
      heroImage: data.heroImage || "",
      serverAdmin: {
        role: data.serverAdmin?.role || "Server Admin",
        name: data.serverAdmin?.name || "",
        email: data.serverAdmin?.email || "",
      },
      contacts: Array.isArray(data.contacts) ? data.contacts.map(normalizeContactPerson) : [],
      socials: Array.isArray(data.socials) ? data.socials.map(normalizeContactSocial) : [],
    });

    const galleryColumnCount = 3;

    const normalizeGalleryGridRows = (value) => Math.max(1, Math.min(24, Number(value) || 6));

    const galleryBlockCells = (blocks) => {
      if (String(blocks) === "2v") {
        return [0, 3];
      }
      const value = Number(blocks) || 1;
      if (value === 2) {
        return [0, 1];
      }
      if (value === 4) {
        return [0, 1, 3, 4];
      }
      if (value === 6) {
        return [0, 1, 2, 3, 4, 5];
      }
      return [0];
    };

    const normalizeGallerySize = (size) => {
      if (String(size) === "2v") {
        return "2v";
      }
      const value = Number(size) || 1;
      return [1, 2, 4, 6].includes(value) ? value : 1;
    };

    const isVideoPath = (path) => /\.(mp4|webm|mov|m4v)(\?.*)?$/i.test(String(path || ""));

    const youtubeIdFromUrl = (value) => {
      const source = String(value || "").trim();
      if (!source) {
        return "";
      }

      try {
        const url = new URL(source);
        const hostname = url.hostname.replace(/^www\./, "");
        if (hostname === "youtu.be") {
          return url.pathname.split("/").filter(Boolean)[0] || "";
        }
        if (hostname === "youtube.com" || hostname === "m.youtube.com") {
          const directId = url.searchParams.get("v");
          if (directId) {
            return directId;
          }
          const parts = url.pathname.split("/").filter(Boolean);
          if ((parts[0] === "embed" || parts[0] === "shorts") && parts[1]) {
            return parts[1];
          }
        }
      } catch {
        return "";
      }

      return "";
    };

    const normalizeGalleryMediaType = (item, size) => {
      const isYoutube = item.mediaType === "youtube" || Boolean(youtubeIdFromUrl(item.image));
      const isVideo = item.mediaType === "video" || isVideoPath(item.image);
      return size === 6 && isYoutube ? "youtube" : isVideo && size === 6 ? "video" : "image";
    };

    const gallerySizeOptions = [
      { value: 1, label: "1" },
      { value: 2, label: "2가로" },
      { value: "2v", label: "2세로" },
      { value: 4, label: "4" },
      { value: 6, label: "6" },
    ];

    const galleryPlacementCells = (startCell, size, gridRows) => {
      const row = Math.floor(startCell / galleryColumnCount);
      const column = startCell % galleryColumnCount;
      const normalizedSize = normalizeGallerySize(size);
      const startColumn =
        normalizedSize === 1 || normalizedSize === "2v"
          ? column
          : normalizedSize === 2 || normalizedSize === 4
            ? Math.min(column, 1)
            : 0;
      const startRow =
        normalizedSize === 1 || normalizedSize === 2
          ? row
          : Math.min(row, Math.max(0, gridRows - 2));
      const width = normalizedSize === "2v" || normalizedSize === 1 ? 1 : normalizedSize === 2 || normalizedSize === 4 ? 2 : 3;
      const height = normalizedSize === 1 || normalizedSize === 2 ? 1 : 2;
      const cells = [];

      for (let rowOffset = 0; rowOffset < height; rowOffset += 1) {
        for (let columnOffset = 0; columnOffset < width; columnOffset += 1) {
          cells.push((startRow + rowOffset) * galleryColumnCount + startColumn + columnOffset);
        }
      }

      return cells;
    };

    const normalizeGalleryCells = (cells, gridRows, fallbackBlocks = 1) => {
      const maxCells = normalizeGalleryGridRows(gridRows) * galleryColumnCount;
      const source = Array.isArray(cells) && cells.length ? cells : galleryBlockCells(fallbackBlocks);
      const uniqueCells = [...new Set(source.map((cell) => Number(cell)).filter((cell) => Number.isInteger(cell) && cell >= 0 && cell < maxCells))];

      if (!uniqueCells.length) {
        return [0];
      }

      const rows = uniqueCells.map((cell) => Math.floor(cell / galleryColumnCount));
      const columns = uniqueCells.map((cell) => cell % galleryColumnCount);
      const minRow = Math.min(...rows);
      const maxRow = Math.max(...rows);
      const minColumn = Math.min(...columns);
      const maxColumn = Math.max(...columns);
      const rectCells = [];

      for (let row = minRow; row <= maxRow; row += 1) {
        for (let column = minColumn; column <= maxColumn; column += 1) {
          const cell = row * galleryColumnCount + column;
          if (cell < maxCells) {
            rectCells.push(cell);
          }
        }
      }

      return rectCells;
    };

    const legacyGalleryItems = (data = {}) => {
      if (Array.isArray(data.items)) {
        return data.items;
      }

      let rowOffset = 0;
      return (Array.isArray(data.rows) ? data.rows : []).flatMap((row) => {
        const rowGridRows = normalizeGalleryGridRows(row.gridRows || 2);
        const items = (Array.isArray(row.items) ? row.items : []).map((item) => ({
          ...item,
          cells: normalizeGalleryCells(item.cells, rowGridRows, item.blocks).map((cell) => cell + rowOffset * galleryColumnCount),
        }));
        rowOffset += rowGridRows;
        return items;
      });
    };

    const normalizeGalleryItem = (item = {}, gridRows = 6, index = 0) => {
      const size = normalizeGallerySize(item.size || item.blocks);
      return {
        id: Number(item.id) || index + 1,
        title: item.title || item.caption || `Photo ${index + 1}`,
        image: item.image || "",
        alt: item.alt || item.title || "",
        mediaType: normalizeGalleryMediaType(item, size),
        size,
        placed: item.placed !== false,
        cells: item.placed === false ? [] : normalizeGalleryCells(item.cells, gridRows, item.blocks || item.size),
      };
    };

    const moveGalleryItemRows = (item, rowDelta, gridRows, index) => {
      const normalizedItem = normalizeGalleryItem(item, Math.max(1, gridRows), index);
      if (normalizedItem.placed === false) {
        return normalizedItem;
      }

      const shiftedCells = normalizedItem.cells.map((cell) => cell + rowDelta * galleryColumnCount);
      const maxCell = gridRows * galleryColumnCount;
      const isOutOfBounds = shiftedCells.some((cell) => cell < 0 || cell >= maxCell);

      if (isOutOfBounds) {
        return {
          ...normalizedItem,
          placed: false,
          cells: [],
        };
      }

      return {
        ...normalizedItem,
        cells: shiftedCells,
      };
    };

    const normalizeGalleryData = (data = {}) => {
      const gridRows = normalizeGalleryGridRows(data.gridRows || 6);
      return {
        title: data.title || "Gallery",
        description: data.description || "",
        gridRows,
        items: legacyGalleryItems(data).map((item, index) => normalizeGalleryItem(item, gridRows, index)),
      };
    };

    const normalizeVisitsData = (data = {}) => ({
      total: Number(data.total) || 0,
      pages: data.pages && typeof data.pages === "object" ? data.pages : {},
      days: data.days && typeof data.days === "object" ? data.days : {},
      updatedAt: data.updatedAt || "",
    });

    const formatCount = (value) => (Number(value) || 0).toLocaleString("ko-KR");

    const pageVisitCountFrom = (pages, route) => {
      if (route === "all") {
        return Object.values(pages).reduce((sum, count) => sum + (Number(count) || 0), 0);
      }
      if (route === "/members") {
        return Object.entries(pages).reduce(
          (sum, [path, count]) => sum + (path === "/members" || path.startsWith("/members/") ? Number(count) || 0 : 0),
          0,
        );
      }
      return Number(pages[route]) || 0;
    };

    const pageVisitCount = (route) => {
      if (route === "all") {
        return Number(visitsData.total) || pageVisitCountFrom(visitsData.pages, "all");
      }
      return pageVisitCountFrom(visitsData.pages, route);
    };

    const visitDayKey = (date) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    };

    const recentVisitDays = () => {
      const today = new Date();
      const dayMs = 24 * 60 * 60 * 1000;
      return Array.from({ length: 7 }, (_, index) => {
        const date = new Date(today.getTime() - (6 - index) * dayMs);
        return {
          key: visitDayKey(date),
          label: `${date.getMonth() + 1}/${date.getDate()}`,
        };
      });
    };

    const selectedVisitLabel = () => {
      if (selectedVisitRoute === "all") {
        return "전체 페이지";
      }
      return sitePages.find((page) => page.route === selectedVisitRoute)?.name || selectedVisitRoute;
    };

    const visitSeries = () =>
      recentVisitDays().map((day) => {
        const dayData = visitsData.days[day.key] || { total: 0, pages: {} };
        const count = selectedVisitRoute === "all" ? Number(dayData.total) || 0 : pageVisitCountFrom(dayData.pages || {}, selectedVisitRoute);
        return { ...day, count };
      });

    const renderVisitChart = () => {
      const series = visitSeries();
      const weekTotal = series.reduce((sum, day) => sum + day.count, 0);
      const maxCount = Math.max(1, ...series.map((day) => day.count));
      const total = pageVisitCount(selectedVisitRoute);
      const updated = visitsData.updatedAt ? new Date(visitsData.updatedAt).toLocaleString("ko-KR") : "기록 없음";
      const label = selectedVisitLabel();

      adminVisitSummary.innerHTML = `
        <span>${escapeHtml(label)} 총 조회수 <strong>${formatCount(total)}</strong></span>
        <span>최근 7일 <strong>${formatCount(weekTotal)}</strong></span>
        <span>최근 기록 ${escapeHtml(updated)}</span>
      `;

      adminVisitChart.innerHTML = series
        .map(
          (day) => `
            <div class="admin-visit-bar-row">
              <span class="admin-visit-day">${escapeHtml(day.label)}</span>
              <span class="admin-visit-bar-track">
                <span class="admin-visit-bar-fill" style="width: ${(day.count / maxCount) * 100}%"></span>
              </span>
              <span class="admin-visit-count">${formatCount(day.count)}</span>
            </div>
          `,
        )
        .join("");
    };

    const renderVisitPageSelect = () => {
      const routes = new Set(sitePages.map((page) => page.route));
      if (selectedVisitRoute !== "all" && !routes.has(selectedVisitRoute)) {
        selectedVisitRoute = "all";
      }

      adminVisitPageSelect.innerHTML = `
        <option value="all" ${selectedVisitRoute === "all" ? "selected" : ""}>전체 페이지</option>
        ${sitePages
          .map(
            (page) => `
              <option value="${escapeHtml(page.route)}" ${selectedVisitRoute === page.route ? "selected" : ""}>
                ${escapeHtml(page.name)} (${escapeHtml(page.route)})
              </option>
            `,
          )
          .join("")}
      `;
    };

    const setEditorChrome = (editor) => {
      activeEditor = editor;
      const isMembers = editor === "members";
      const titles = {
        members: "Members",
        home: "Home",
        "home-en": "Home EN",
        intro: "About US",
        "intro-en": "About US EN",
        history: "Our Cars",
        gallery: "Gallery",
        sponsors: "Sponsors",
        contact: "Contact US",
      };
      adminEditorTitle.textContent = titles[editor] || "Editor";
      membersItemField.hidden = !isMembers;
      addSeasonButton.hidden = !isMembers;
    };

    const renderPageList = () => {
      renderVisitPageSelect();
      renderVisitChart();
      adminPageGrid.innerHTML = sitePages
        .map((page) => {
          const editableClass = page.editor ? " is-editable" : "";
          const action = page.editor ? ` data-action="open-editor" data-editor="${escapeHtml(page.editor)}"` : "";
          const tag = page.editor ? "button" : "div";
          const type = page.editor ? ' type="button"' : "";
          const visits = pageVisitCount(page.route);

          return `
            <${tag} class="admin-page-card${editableClass}"${type}${action}>
              <span class="admin-page-name">${escapeHtml(page.name)}</span>
              <span class="admin-page-route">${escapeHtml(page.route)}</span>
              <span class="admin-page-visits">조회수 ${formatCount(visits)}</span>
              <span class="admin-page-file">${escapeHtml(page.file)}</span>
            </${tag}>
          `;
        })
        .join("");
    };

    const sortSeasons = () =>
      membersData.seasons.sort((a, b) => Number(b.year) - Number(a.year));

    const selectedKind = () => {
      if (selectedYear === "archive" || selectedYear === "ob") {
        return selectedYear;
      }
      return "season";
    };

    const selectedUploadBucket = () =>
      selectedYear.startsWith("season:") ? selectedYear.slice("season:".length) : selectedYear || "general";

    const currentSeason = () => {
      if (selectedKind() !== "season") {
        return null;
      }

      const selectedSeasonYear = selectedUploadBucket();
      const season = membersData.seasons.find((item) => item.year === selectedSeasonYear) || membersData.seasons[0];
      selectedYear = season ? `season:${season.year}` : "";
      return season;
    };

    const nextSeasonYear = () => {
      const years = membersData.seasons.map((season) => Number(season.year)).filter(Number.isFinite);
