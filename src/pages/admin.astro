    const galleryFilteredEntries = () =>
      galleryData.items
        .map((item, index) => ({ item, index }))
        .filter(({ item }) => {
          if (selectedGalleryFilter === "placed") {
            return item.placed !== false;
          }
          if (selectedGalleryFilter === "unplaced") {
            return item.placed === false;
          }
          return true;
        });

    const galleryPageCount = () => Math.max(1, Math.ceil(galleryFilteredEntries().length / galleryPageSize));

    const clampGalleryPage = () => {
      selectedGalleryPage = Math.max(1, Math.min(selectedGalleryPage, galleryPageCount()));
    };

    const ensureSelectedGalleryVisible = () => {
      const entries = galleryFilteredEntries();
      const filteredIndex = entries.findIndex((entry) => entry.index === selectedGalleryItemIndex);
      if (filteredIndex >= 0) {
        selectedGalleryPage = Math.floor(filteredIndex / galleryPageSize) + 1;
      }
      clampGalleryPage();
    };

