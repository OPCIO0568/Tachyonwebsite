      const selectedItem = selectedGalleryItem();
      const selectedCells = new Set(selectedItem?.placed === false ? [] : selectedItem ? normalizeGalleryCells(selectedItem.cells, galleryData.gridRows) : []);
      return Array.from({ length: galleryData.gridRows * galleryColumnCount }, (_, cellIndex) => {
        const ownerIndex = galleryCellOwner(cellIndex);
        const isCurrent = ownerIndex === selectedGalleryItemIndex;
        const isBlocked = ownerIndex !== -1 && !isCurrent;
        const classes = [
          "admin-gallery-board-cell",
          selectedCells.has(cellIndex) ? "is-selected" : "",
          isBlocked ? "is-blocked" : "",
        ]
          .filter(Boolean)
          .join(" ");
        const label = isBlocked ? galleryItemLabel(galleryData.items[ownerIndex], ownerIndex) : selectedCells.has(cellIndex) ? galleryItemLabel(selectedItem, selectedGalleryItemIndex) : "";

        return `
          <button class="${classes}" type="button" data-action="place-gallery-item" data-cell-index="${cellIndex}" ${isBlocked || !selectedItem ? "disabled" : ""}>
            ${escapeHtml(label)}
          </button>
