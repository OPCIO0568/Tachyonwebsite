---
import BaseLayout from "../layouts/BaseLayout.astro";
import fallbackContactData from "../../data/contact.json";
import { renderContact } from "../utils/publicContent.js";
---

<BaseLayout title={fallbackContactData.title} description={fallbackContactData.subtitle || "Tachyon contact information"}>
  <section class="section">
    <div class="container" id="contact-app">
      <Fragment set:html={renderContact(fallbackContactData)} />
    </div>
  </section>

  <script>
    import { normalizeContact, renderContact } from "../utils/publicContent.js";

    const app = document.getElementById("contact-app");

    const render = (data) => {
      const contact = normalizeContact(data);
      document.title = contact.title;
      document
        .querySelector('meta[name="description"]')
        ?.setAttribute("content", contact.subtitle || "Tachyon contact information");
      app.innerHTML = renderContact(data);
    };

    const loadContact = async () => {
      try {
        const response = await fetch("/api/contact", { cache: "no-store" });
        if (!response.ok) {
          throw new Error("Failed to load contact");
        }
        return await response.json();
      } catch {
        return null;
      }
    };

    loadContact().then((data) => {
      if (data) {
        render(data);
      }
    });
  </script>
</BaseLayout>
