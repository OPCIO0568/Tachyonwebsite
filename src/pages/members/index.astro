---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fallbackMembersData from "../../../data/members.json";
import { defaultMembersView, renderMembers } from "../../utils/publicContent.js";
---

<BaseLayout title="Members" description="Tachyon members">
  <section class="section">
    <div class="container">
      <div id="members-app" class="members-app">
        <Fragment set:html={renderMembers(fallbackMembersData, defaultMembersView(fallbackMembersData))} />
      </div>
    </div>
  </section>

  <script>
    import { renderMembers } from "../../utils/publicContent.js";

    const app = document.getElementById("members-app");

    const sortSeasons = (seasons) => [...(seasons ?? [])].sort((a, b) => Number(b.year) - Number(a.year));

    const getInitialView = (data) => {
      const params = new URLSearchParams(window.location.search);
      const pathMatch = window.location.pathname.match(/^\/members\/([^/]+)\/?$/);
      const pathView = pathMatch?.[1];
      const year = pathView || params.get("year");

      if (year && data.seasons?.some((season) => season.year === year)) {
        return { type: "season", year };
      }
      if (pathView === "archive" || params.get("view") === "archive") {
        return { type: "archive" };
      }
      if (pathView === "ob" || params.get("view") === "ob") {
        return { type: "ob" };
      }
      return { type: "season", year: sortSeasons(data.seasons)[0]?.year };
    };

    const render = (data, view) => {
      app.innerHTML = renderMembers(data, view);
    };

    const setUrl = (view) => {
      const url = new URL(window.location.href);
      url.search = "";
      if (view.type === "season" && view.year) {
        url.pathname = `/members/${view.year}`;
      } else if (view.type === "archive" || view.type === "ob") {
        url.pathname = `/members/${view.type}`;
      } else {
        url.pathname = "/members";
      }
      window.history.pushState(view, "", url);
    };

    const loadMembersData = async () => {
      try {
        const response = await fetch("/api/members", { cache: "no-store" });
        if (!response.ok) {
          throw new Error("Failed to load members");
        }
        return await response.json();
      } catch {
        return null;
      }
    };

    const copyToClipboard = async (text) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.append(textarea);
      textarea.select();
      document.execCommand("copy");
      textarea.remove();
    };

    const showCopyState = (button, label, className) => {
      const originalLabel = button.dataset.label || button.textContent;
      button.dataset.label = originalLabel;
      button.textContent = label;
      button.classList.add(className);

      window.setTimeout(() => {
        button.textContent = originalLabel;
        button.classList.remove(className);
      }, 1400);
    };

    const init = async () => {
      try {
        let data = null;
        let active = null;

        app.addEventListener("click", async (event) => {
          const emailButton = event.target.closest(".member-email-copy");
          if (emailButton) {
            try {
              await copyToClipboard(emailButton.dataset.email || "");
              showCopyState(emailButton, "Copied", "is-copied");
            } catch {
              showCopyState(emailButton, "Failed", "is-copy-failed");
            }
            return;
          }

          const tab = event.target.closest(".member-tab");
          if (!tab || !data) {
            return;
          }

          active = tab.dataset.year ? { type: "season", year: tab.dataset.year } : { type: tab.dataset.view };
          render(data, active);
          setUrl(active);
        });

        window.addEventListener("popstate", () => {
          if (!data) {
            return;
          }
          active = getInitialView(data);
          render(data, active);
        });

        data = await loadMembersData();
        if (data) {
          active = getInitialView(data);
          render(data, active);
        }
      } catch {
        app.innerHTML = `
          <h1 class="section-title">Members</h1>
          <p class="section-subtitle">멤버 정보를 표시하지 못했습니다. 데이터 형식을 확인해주세요.</p>
        `;
      }
    };

    init();
  </script>
</BaseLayout>
