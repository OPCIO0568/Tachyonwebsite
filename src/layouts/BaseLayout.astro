---
import "../styles/global.css";

const {
  title = "Tachyon",
  description = "충북대학교 자작 포뮬러 자동차 동아리",
} = Astro.props;

const currentPath =
  Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, "") : Astro.url.pathname;
const isEnglish = currentPath.startsWith("/en");
const langEnabledPaths = ["/", "/intro", "/en", "/en/intro"];
const hasLangToggle = langEnabledPaths.includes(currentPath);
const homeHref = isEnglish ? "/en" : "/";
const introHref = isEnglish ? "/en/intro" : "/intro";
const langHrefMap = {
  "/": "/en",
  "/intro": "/en/intro",
  "/en": "/",
  "/en/intro": "/intro",
};
const langHref = langHrefMap[currentPath] ?? (isEnglish ? "/" : "/en");
const langLabel = isEnglish ? "KR" : "EN";
const htmlLang = isEnglish ? "en" : "ko";
const currentYear = new Date().getFullYear();
const siteOrigin = "https://tachyon.cbnu.ac.kr";
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const imageUrl = new URL("/images/tachyon-logo-link.png", siteOrigin).toString();
const isAdminPage = currentPath.startsWith("/admin");
const fullTitle = title === "Tachyon" ? title : `${title} | Tachyon`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={isAdminPage ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/images/tachyon-logo-link.png" />
    <meta property="og:site_name" content="Tachyon" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/">
          <img class="brand-logo" src="/images/tachyon-logo2.png" alt="Tachyon logo" />
          <span>Tachyon</span>
        </a>
        <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="site-navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="header-actions">
          <nav class="nav-links" id="site-navigation">
            <a href={homeHref}>Home</a>
            <a href={introHref}>About US</a>
            <a href="/history">Our Cars</a>
            <a href="/members">Members</a>
            <a href="/gallery">Gallery</a>
            <a href="/sponsors">Sponsors</a>
            <a href="/contact">Contact US</a>
            {hasLangToggle && (
              <a class="lang-toggle" href={langHref} aria-label="Switch language">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm7.74 9h-3.12a15.4 15.4 0 00-1.3-5.01A8.02 8.02 0 0119.74 11zM12 4.1c1.1 1.45 1.88 3.25 2.25 5.2h-4.5c.37-1.95 1.15-3.75 2.25-5.2zM4.26 13h3.12c.26 1.74.8 3.39 1.58 4.87A8.03 8.03 0 014.26 13zm3.12-2H4.26a8.03 8.03 0 014.7-4.87c-.78 1.48-1.32 3.13-1.58 4.87zm2.37 2h4.5c-.37 1.95-1.15 3.75-2.25 5.2-1.1-1.45-1.88-3.25-2.25-5.2zm7.87 0h3.12a8.02 8.02 0 01-4.7 4.87c.78-1.48 1.32-3.13 1.58-4.87zm0-2c-.26-1.74-.8-3.39-1.58-4.87A8.02 8.02 0 0119.74 11h-3.12z" />
                </svg>
                <span>{langLabel}</span>
              </a>
            )}
          </nav>
        </div>
      </div>
    </header>

    <script is:inline>
      const header = document.querySelector(".site-header");
      const navToggle = document.querySelector(".nav-toggle");
      const navLinks = document.querySelector(".nav-links");

      const setMenuOpen = (isOpen) => {
        header?.toggleAttribute("data-nav-open", isOpen);
        navToggle?.setAttribute("aria-expanded", String(isOpen));
        navToggle?.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      };

      navToggle?.addEventListener("click", () => {
        setMenuOpen(navToggle.getAttribute("aria-expanded") !== "true");
      });

      navLinks?.addEventListener("click", (event) => {
        if (event.target.closest("a")) {
          setMenuOpen(false);
        }
      });

      document.addEventListener("click", (event) => {
        if (!header?.contains(event.target)) {
          setMenuOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setMenuOpen(false);
        }
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span>ⓒ {currentYear} Tachyon</span>
        <div class="footer-social">
          <a href="https://www.instagram.com/cbnu_tachyon/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7.5 2C4.462 2 2 4.462 2 7.5v9C2 19.538 4.462 22 7.5 22h9c3.038 0 5.5-2.462 5.5-5.5v-9C22 4.462 19.538 2 16.5 2h-9zm0 2h9C18.43 4 20 5.57 20 7.5v9c0 1.93-1.57 3.5-3.5 3.5h-9C5.57 20 4 18.43 4 16.5v-9C4 5.57 5.57 4 7.5 4zm9.25 2a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z" />
            </svg>
            Instagram
          </a>
          <a href="https://cafe.naver.com/tachyonformula/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M2 3.6h5.2l4.6 6.6V3.6H22v16.8h-5.2l-4.6-6.6v6.6H2z" />
            </svg>
            Naver Cafe
          </a>
          <a href="http://www.youtube.com/@CBNUTACHYON/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21.58 7.19a2.75 2.75 0 00-1.94-1.94C17.76 4.5 12 4.5 12 4.5s-5.76 0-7.64.75a2.75 2.75 0 00-1.94 1.94A28.45 28.45 0 002 12a28.45 28.45 0 00.42 4.81 2.75 2.75 0 001.94 1.94C6.24 19.5 12 19.5 12 19.5s5.76 0 7.64-.75a2.75 2.75 0 001.94-1.94A28.45 28.45 0 0022 12a28.45 28.45 0 00-.42-4.81zM10 15.27V8.73L15.5 12 10 15.27z" />
            </svg>
            YouTube
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
